<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#AA8B7FFF" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="#443D2B8F"
                android:endColor="#445B4FBF"
                android:angle="135" />
            <corners android:radius="10dp" />
            <stroke android:color="#669B7FFF" android:width="1dp" />
        </shape>
    </item>
</selector>
